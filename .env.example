# Neon: https://neon.tech — use pooled connection for serverless (Vercel).
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Required for sign-in. If you see "server configuration" on Vercel, this (or NEXTAUTH_SECRET) is missing for Production.
# openssl rand -base64 32
AUTH_SECRET=""
# NEXTAUTH_SECRET="optional-legacy-same-value"

# Local + LAN + Vercel: keep trustHost for flexible hosts.
AUTH_TRUST_HOST=true
# Local: localhost. Vercel: set to your production URL, e.g. https://your-app.vercel.app
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Optional: OpenAI for AI workout plans
OPENAI_API_KEY=""

# After first deploy, run db push + seed against Neon (local CLI or Vercel build has db push in npm run build).
